          {topic.subtitle}
        </p>

        <div className=\"mt-4 flex items-center justify-between\">
          <StarBar earned={stars} total={totalStars} />
          <span className=\"inline-flex items-center gap-1 font-display text-sm font-bold text-stone-900\">
            Let's go
            <ArrowUpRight
              strokeWidth={3}
              className=\"h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5\"
            />
          </span>
        </div>
      </div>
    </Link>
  );
};

export default TopicCard;
