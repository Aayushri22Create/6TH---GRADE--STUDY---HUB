          src={topic.cover}
          alt={topic.title}
          loading=\"lazy\"
          className=\"h-full w-full object-cover\"
          onError={(e) => {
            e.currentTarget.style.display = \"none\";
          }}
        />
        <span
          className=\"absolute top-3 left-3 inline-flex items-center gap-2 rounded-full border-[3px] border-stone-900 bg-white px-3 py-1 font-display font-bold text-xs\"
          data-testid={`topic-emoji-${topic.id}`}
