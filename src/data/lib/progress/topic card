  return (
    <div className=\"flex items-center gap-1\" aria-label={`${earned} of ${total} stars`}>
      {Array.from({ length: total }).map((_, i) => (
        <Star
          key={i}
          strokeWidth={3}
          className={`h-4 w-4 ${
